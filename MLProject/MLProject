name: titanic-survival-prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      dataset_path:
        type: str
        default: "titanic_preprocessing.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 5
      min_samples_split:
        type: int
        default: 4
      min_samples_leaf:
        type: int
        default: 2
    command: >
      python modelling.py
      --dataset {dataset_path}
      --n-estimators {n_estimators}
      --max-depth {max_depth}
      --min-samples-split {min_samples_split}
      --min-samples-leaf {min_samples_leaf}